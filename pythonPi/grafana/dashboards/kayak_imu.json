{
  "title": "Kayak IMU",
  "uid": "ekayak-kayak-imu",
  "tags": [
    "e-kayak"
  ],
  "timezone": "browser",
  "refresh": "100ms",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "session",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-ekayak"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"session\", predicate: (r) => r._measurement == \"kayak_imu\", start: -30d)",
        "refresh": 2,
        "sort": 2,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Heading",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"heading\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Roll / Pitch",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"roll\" or r._field == \"pitch\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Acceleration (X / Y / Z)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "accMS2",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"accel_x\" or r._field == \"accel_y\" or r._field == \"accel_z\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Gyroscope (X / Y / Z)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrads",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"gyro_x\" or r._field == \"gyro_y\" or r._field == \"gyro_z\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Calibration Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 3,
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"cal_sys\" or r._field == \"cal_gyro\" or r._field == \"cal_accel\" or r._field == \"cal_mag\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Read Health",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "read_rate_hz"
            },
            "properties": [
              {
                "id": "unit",
                "value": "hertz"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*_ms$"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "read_drop_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"kayak_imu\")\n  |> filter(fn: (r) => r._field == \"read_rate_hz\" or r._field == \"read_delta_ms\" or r._field == \"read_jitter_ms\" or r._field == \"read_drop_pct\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    }
  ]
}
