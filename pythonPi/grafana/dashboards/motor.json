{
  "title": "Motor",
  "uid": "ekayak-motor",
  "tags": [
    "e-kayak"
  ],
  "timezone": "browser",
  "refresh": "100ms",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "session",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-ekayak"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"session\", predicate: (r) => r._measurement == \"motor\", start: -30d)",
        "refresh": 2,
        "sort": 2,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "RPM \u2014 Commanded vs Filtered vs Actual",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rpm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "commanded_rpm"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    5
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor_cmd\")\n  |> filter(fn: (r) => r._field == \"commanded_rpm\" or r._field == \"filtered_rpm\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\" and r._field == \"rpm\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Voltage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\" and r._field == \"voltage_in\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Current",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\")\n  |> filter(fn: (r) => r._field == \"current_in\" or r._field == \"motor_current\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Power",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\" and r._field == \"power\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "FET Temperature",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 45
              },
              {
                "color": "red",
                "value": 53
              }
            ]
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\" and r._field == \"temp_fets\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Energy Consumed",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "amp_hours"
            },
            "properties": [
              {
                "id": "unit",
                "value": "Ah"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "watt_hours"
            },
            "properties": [
              {
                "id": "unit",
                "value": "Wh"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\")\n  |> filter(fn: (r) => r._field == \"amp_hours\" or r._field == \"watt_hours\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Fault Code",
      "type": "state-timeline",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "left"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"motor\" and r._field == \"fault_code\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    }
  ]
}