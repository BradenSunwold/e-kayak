{
  "title": "Stroke Detector",
  "uid": "ekayak-stroke-detector",
  "tags": [
    "e-kayak",
    "ml"
  ],
  "timezone": "browser",
  "refresh": "100ms",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "session",
        "type": "query",
        "datasource": {
          "type": "influxdb",
          "uid": "influxdb-ekayak"
        },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"session\", predicate: (r) => r._measurement == \"stroke_detector\", start: -30d)",
        "refresh": 2,
        "sort": 2,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Stroke Probability",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"stroke_detector\")\n  |> filter(fn: (r) => r._field == \"probability_stroke\" or r._field == \"probability_no_stroke\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Predicted Class",
      "type": "state-timeline",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "no_stroke",
                  "color": "blue"
                },
                "1": {
                  "text": "stroke",
                  "color": "green"
                }
              }
            }
          ],
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "alignValue": "left"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"stroke_detector\" and r._field == \"probability_stroke\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")\n  |> map(fn: (r) => ({ r with _value: if r._value >= 0.75 then 1 else 0 }))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Inference Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"stroke_detector\" and r._field == \"inference_latency_milliseconds\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Paddle Acceleration (X / Y / Z)",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "unit": "accMS2",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "pointSize": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb-ekayak"
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"imu\" and (r.mode == \"auto\" or r.mode == \"training\"))\n  |> filter(fn: (r) => r._field == \"accel_x\" or r._field == \"accel_y\" or r._field == \"accel_z\")\n  |> filter(fn: (r) => if \"${session}\" == \"$__all\" then true else r.session == \"${session}\")",
          "refId": "A"
        }
      ]
    }
  ]
}
